# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_random_64_character_string_before_deploying
JWT_EXPIRES_IN=7d

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_PATH=./db/affiliate_launchpad.db
# For Railway with a mounted volume:
# DATABASE_PATH=/app/data/affiliate_launchpad.db

# ─── GoHighLevel Integration ──────────────────────────────────────────────────
# Set a secret string — enter this same value in GHL's webhook header config
GHL_WEBHOOK_SECRET=your_ghl_webhook_secret_here
# Your GHL outbound webhook URL (receives Closed Won events from this app)
GHL_WEBHOOK_URL=https://hooks.gohighlevel.com/YOUR_HOOK_ID
# GHL API key (for future direct API use)
GHL_API_KEY=your_ghl_api_key_here

# ─── Email Notifications (SMTP) ───────────────────────────────────────────────
# For Gmail: enable App Passwords at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password

# Notification recipient (your admin email)
NOTIFY_EMAIL=admin@affiliatelaunchpad.com

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Development
FRONTEND_URL=http://localhost:5173
# Production (your Railway or custom domain)
# FRONTEND_URL=https://os.affiliatelaunchpad.com

# ─── Calendly (optional — for webhook verification) ───────────────────────────
CALENDLY_WEBHOOK_SECRET=your_calendly_webhook_secret_here
